# 여기콕 운영 환경변수 예시. 이 파일을 deploy/.env 로 복사해 실제 값을 채운다.
# deploy/.env 는 git에 올리지 않는다(.gitignore 등록됨). 지갑 파일은 ./wallet 폴더에 둔다.

# DB (Oracle ADB) - 지갑은 컨테이너에 /app/wallet 로 마운트되므로 별칭만 지정
DB_TNS_ALIAS=dinkdb_medium
DB_USERNAME=DA2617
DB_PASSWORD=change-me
# DB_WALLET_DIR / TNS_ADMIN 은 docker-compose.yml 이 /app/wallet 로 고정 주입한다

# HTTPS 뒤에 두므로 세션 쿠키 secure 강제(prod 프로파일이 기본 true지만 명시)
SESSION_COOKIE_SECURE=true

# 관리자 보안
# ADMIN_TRUST_DEVICE_SECRET 은 prod 필수(미설정 시 기동 중단). 32자 이상 랜덤 권장.
ADMIN_TRUST_DEVICE_SECRET=change-me-to-a-long-random-string
# 관리자 접근 허용 IP 대역(쉼표 구분, 비우면 전체 허용)
ADMIN_IP_ALLOWLIST=

# 외부 API 키
KAKAO_JS_KEY=
KAKAO_REST_KEY=
DATAGOKR_SERVICE_KEY=
SEOUL_OPENDATA_KEY=
FTC_FRANCHISE_KEY=
REB_RONE_KEY=
KIPRIS_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
BIZINFO_SERVICE_KEY=
KSTARTUP_SERVICE_KEY=

# 결제(토스) - 없으면 결제 기능 비활성
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# AI(Gemini) - 없으면 AI 리포트/뉴스 요약 비활성
GEMINI_API_KEY=
GEMINI_API_NEWS_KEY=

# 배치 실패 알림 웹훅(Slack 호환) - 없으면 알림 비활성
OPS_ALERT_WEBHOOK_URL=
