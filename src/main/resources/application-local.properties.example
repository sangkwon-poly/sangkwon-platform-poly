# 로컬 전용 설정 템플릿
# 이 파일을 복사해서 application-local.properties 로 저장하고 실제 값을 채우세요.
#   (application-local.properties 는 .gitignore 에 등록돼 깃허브에 올라가지 않습니다)
#
# 실행: ./gradlew bootRun --args='--spring.profiles.active=local'
# 값은 조장에게 받거나 각 API 발급처에서 받으세요.

# Oracle DB (클라우드 ADB, 지갑 방식)
DB_TNS_ALIAS=여기에_TNS_별칭        # 예: dinkdb_medium
DB_WALLET_DIR=여기에_지갑_폴더_절대경로   # 각자 PC의 지갑 압축 푼 경로
DB_USERNAME=여기에_계정명
DB_PASSWORD=여기에_비밀번호

# 로컬 Oracle XE로 쓰려면 위 4줄 대신 아래 3줄 사용
#spring.datasource.url=jdbc:oracle:thin:@localhost:1521/XEPDB1
#spring.datasource.username=여기에_계정명
#spring.datasource.password=여기에_비밀번호

# 개발 중 실행 SQL을 콘솔에 보려면 켜세요 (base 설정에서 옮겨온 항목)
#spring.jpa.show-sql=true

# 외부 API 키
KAKAO_JS_KEY=여기에_카카오_JS_키
KAKAO_REST_KEY=여기에_카카오_REST_키
DATAGOKR_SERVICE_KEY=여기에_data.go.kr_일반인증키
SEOUL_OPENDATA_KEY=여기에_서울_열린데이터광장_인증키
FTC_FRANCHISE_KEY=여기에_franchise.ftc.go.kr_키
REB_RONE_KEY=여기에_R-ONE_키

# 창업지원/기업정보 API 키
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_시크릿
DART_API_KEY=여기에_DART_키
KIPRIS_API_KEY=여기에_KIPRIS_키
BIZINFO_SERVICE_KEY=여기에_기업마당_인증키
KSTARTUP_SERVICE_KEY=여기에_K-Startup_키
